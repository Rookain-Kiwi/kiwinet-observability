# Stack monitoring — kiwinet-observability
# Copier ce fichier en .env et renseigner les valeurs
# Ne jamais versionner le .env

# Mot de passe de l'utilisateur PostgreSQL "grafana"
# Doit correspondre exactement au mot de passe défini lors du
# CREATE USER grafana WITH PASSWORD '...' sur l'instance postgres (kiwinet-services)
GRAFANA_DB_PASSWORD=changeme
